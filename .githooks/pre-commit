#!/bin/sh
# Thiele Machine pre-commit hook (marker: thiele-machine-pre-commit)
# ==================================================================
# Detects when a tracked manifest source file is staged and auto-regenerates
# the corresponding manifest, then stages the refreshed manifest so the
# commit stays internally consistent.
#
# Currently watches:
#   artifacts/rtl_pipeline_manifest.json  (regenerated by
#     scripts/generate_rtl_pipeline_manifest.py whenever any path it lists
#     under "files" is staged).
#
# To install:
#   make install-hooks            (or: bash scripts/install-git-hooks.sh)
#
# To bypass for one commit (use sparingly):
#   git commit --no-verify

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

MANIFEST="artifacts/rtl_pipeline_manifest.json"
GENERATOR="scripts/generate_rtl_pipeline_manifest.py"

if [ ! -f "$MANIFEST" ] || [ ! -f "$GENERATOR" ]; then
    exit 0
fi

# Read paths the manifest tracks.
TRACKED=$(python3 -c "
import json, sys
try:
    data = json.load(open('$MANIFEST'))
    for f in data.get('files', []):
        print(f['path'])
except Exception:
    sys.exit(0)
")

[ -z "$TRACKED" ] && exit 0

# Files staged for this commit.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR || true)
[ -z "$STAGED" ] && exit 0

# Did any tracked source change?
needs_refresh=0
for f in $STAGED; do
    for t in $TRACKED; do
        if [ "$f" = "$t" ]; then
            needs_refresh=1
            break 2
        fi
    done
done

if [ "$needs_refresh" = "1" ]; then
    echo "[pre-commit] RTL manifest source changed — regenerating $MANIFEST..."
    python3 "$GENERATOR" --out "$MANIFEST"
    git add "$MANIFEST"
    echo "[pre-commit] $MANIFEST refreshed and staged."
fi

exit 0

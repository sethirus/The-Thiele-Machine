# Full-scale Yosys synthesis script for Thiele CPU (synthesis wrapper)
#
# Uses thiele_cpu_kami_synth.v which implements the same ISA as the
# Kami-extracted thiele_cpu_kami.v but with proper Verilog arrays for
# synthesizable memories. Co-simulation verifies bit-exact equivalence.
#
# Target: completes in <60 seconds on standard hardware.
read_verilog -sv -DSYNTHESIS thiele_cpu_kami_synth.v
synth -top mkModule1
stat
write_verilog -noattr synth_full_out.v

# ULX3S board constraints for Thiele CPU
# Board: Radiona ULX3S v3.x with ECP5 LFE5U-85F-6BG381
#
# To target a different board, create a new .lpf file with your
# board's pin mappings and pass it to nextpnr-ecp5 via --lpf.

LOCATE COMP "CLK"         SITE "G2";    # 25 MHz oscillator
IOBUF  PORT "CLK"         IO_TYPE=LVCMOS33;
FREQUENCY PORT "CLK"      25 MHZ;

LOCATE COMP "RST_N"       SITE "D6";    # Button 0 (active-low active)
IOBUF  PORT "RST_N"       IO_TYPE=LVCMOS33 PULLMODE=UP;

# FTDI UART (active USB channel B, directly on the USB-C connector)
LOCATE COMP "UART_RX"     SITE "M1";    # FTDI TXD → FPGA RX (active receive)
IOBUF  PORT "UART_RX"     IO_TYPE=LVCMOS33;

LOCATE COMP "UART_TX"     SITE "L4";    # FPGA TX → FTDI RXD (active transmit)
IOBUF  PORT "UART_TX"     IO_TYPE=LVCMOS33;

# User LEDs (accent LEDs on top side of board)
LOCATE COMP "LED_HALTED"  SITE "B2";    # LED 0 (accent green)
IOBUF  PORT "LED_HALTED"  IO_TYPE=LVCMOS33;

LOCATE COMP "LED_ERR"     SITE "C2";    # LED 1 (accent red)
IOBUF  PORT "LED_ERR"     IO_TYPE=LVCMOS33;

LOCATE COMP "LED_BIANCHI" SITE "C1";    # LED 2 (accent orange)
IOBUF  PORT "LED_BIANCHI" IO_TYPE=LVCMOS33;

LOCATE COMP "LED_LOADING" SITE "D2";    # LED 3 (accent blue)
IOBUF  PORT "LED_LOADING" IO_TYPE=LVCMOS33;
